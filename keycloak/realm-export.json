{
  "realm": "lab",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 1800,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard-Lab-Benutzer"
      },
      {
        "name": "admin",
        "description": "Lab-Administrator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "lab-spa",
      "name": "Lab SPA (Public Client, PKCE)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "rootUrl": "http://localhost:3012",
      "baseUrl": "http://localhost:3012",
      "redirectUris": [
        "http://localhost:3012/*"
      ],
      "webOrigins": [
        "http://localhost:3012"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3012/*"
      },
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@lab.local",
      "firstName": "Alice",
      "lastName": "Lab",
      "credentials": [
        {
          "type": "password",
          "value": "alice",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "bob",
      "enabled": true,
      "emailVerified": true,
      "email": "bob@lab.local",
      "firstName": "Bob",
      "lastName": "Lab",
      "credentials": [
        {
          "type": "password",
          "value": "bob",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@lab.local",
      "firstName": "Admin",
      "lastName": "Lab",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    }
  ]
}
